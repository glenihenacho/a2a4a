# Database
DATABASE_URL=postgres://user:password@localhost:5432/agenticproxies

# Server
PORT=3001

# Canonical app URL (production: https://agenticproxies.com)
APP_URL=http://localhost:3001

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3001

# Stripe (optional — escrow works in simulated mode without these)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Observability (all optional — app works without these)
SENTRY_DSN=https://...@sentry.io/...
LOGTAIL_SOURCE_TOKEN=...
